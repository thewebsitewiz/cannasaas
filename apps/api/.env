# apps/api/.env.example — copy to apps/api/.env.local

# ── Application
NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ── Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cannasaas
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
RDS_CA_CERT=

# ── Redis
REDIS_URL=redis://:dev_redis_only@localhost:6379
REDIS_PREFIX=cannasaas:

# ── JWT
JWT_SECRET=local-dev-jwt-secret-for-cannasaas-platform-minimum-64-characters-long-abc123
JWT_REFRESH_SECRET=local-dev-refresh-secret-for-cannasaas-platform-minimum-64-characters-xyz789
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
SESSION_FINGERPRINT_SECRET=your-fingerprint-hmac-secret

# ── AWS (development: LocalStack or real AWS with dev IAM role)
AWS_REGION=us-east-1
AWS_S3_BUCKET=cannasaas-assets-dev
AWS_S3_ENDPOINT=
AWS_KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/your-key-id
AWS_SES_FROM_EMAIL=noreply@cannasaas.com

# ── Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+15550000000

# ── Metrc
METRC_INTEGRATOR_API_KEY=your-cannasaas-platform-integrator-api-key
METRC_SANDBOX_MODE=true
METRC_BASE_URL_NY=https://api-ca.metrc.com
METRC_BASE_URL_NJ=https://api-ca.metrc.com
METRC_BASE_URL_CT=https://api-ca.metrc.com

# ── Otreeba
OTREEBA_API_BASE_URL=https://api.otreeba.com/v1
OTREEBA_API_KEY=

# ── OpenSearch
OPENSEARCH_ENDPOINT=http://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin
OPENSEARCH_INDEX_PREFIX=cannasaas_dev_

# ── Encryption
ENCRYPTION_KEY=base64-encoded-32-byte-aes-256-key-replace-in-production

# ── Feature flags
ENABLE_AI_ID_VERIFICATION=false
ENABLE_BUDTENDER_VIDEO=false

NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cannasaas
REDIS_URL=redis://:dev_redis_only@localhost:6379
JWT_SECRET=local-dev-jwt-secret-for-cannasaas-platform-minimum-64-characters-long-abc123
JWT_REFRESH_SECRET=local-dev-refresh-secret-for-cannasaas-platform-minimum-64-characters-xyz789
