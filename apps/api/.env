# ═══════════════════════════════════════════════════════════════════════════
# CannaSaas — Local Development Environment
# ═══════════════════════════════════════════════════════════════════════════

NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177,http://localhost:5178,http://localhost:5176

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cannasaas
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=cannasaas:

# JWT
JWT_SECRET=local-dev-secret-change-in-production-abcdef1234567890
JWT_REFRESH_SECRET=local-dev-refresh-secret-different-abcdef1234567890
JWT_ACCESS_TTL=86400
JWT_REFRESH_TTL=604800

# Encryption
ENCRYPTION_KEY=local-dev-encryption-key-change-me

# Email (disabled in dev — logs to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@localhost
EMAIL_FROM_NAME=CannaSaas Dev

# SMS (disabled in dev)
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# Metrc (sandbox)
METRC_INTEGRATOR_API_KEY=
METRC_SANDBOX_MODE=true
METRC_BASE_URL_NY=https://sandbox-api-ny.metrc.com
METRC_BASE_URL_NJ=https://sandbox-api-nj.metrc.com
METRC_BASE_URL_CT=https://sandbox-api-ct.metrc.com

# Stripe (test keys)
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# Frontend URLs
STOREFRONT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
STAFF_URL=http://localhost:5175,http://localhost:5176,http://localhost:5177,http://localhost:5178
