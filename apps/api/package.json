{
  "dependencies": {
    "@apollo/server": "^4.11.0",
    "@nestjs/apollo": "^12.2.2",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bull": "^10.2.3",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.4.22",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.22",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/graphql": "^12.2.2",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.4.22",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "bullmq": "^5.71.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "graphql": "^16.9.0",
    "graphql-type-json": "^0.3.2",
    "helmet": "^8.0.0",
    "joi": "^17.13.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.16",
    "@swc/core": "^1.10.7",
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.17.14",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  },
  "name": "@cannasaas/api",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "db:migrate": "typeorm migration:run -d src/config/database.config.ts",
    "db:migrate:generate": "typeorm migration:generate -d src/config/database.config.ts",
    "db:seed": "ts-node -r tsconfig-paths/register src/database/seeds/run-seeds.ts",
    "dev": "ts-node --swc -r tsconfig-paths/register src/main.ts",
    "lint": "eslint src --ext .ts",
    "migration:generate": "ts-node --swc -r tsconfig-paths/register ./node_modules/typeorm/cli migration:generate src/migrations/InitialSchema -d src/data-source.ts",
    "migration:revert": "ts-node --swc -r tsconfig-paths/register ./node_modules/typeorm/cli migration:revert -d src/data-source.ts",
    "migration:run": "ts-node --swc -r tsconfig-paths/register ./node_modules/typeorm/cli migration:run -d src/data-source.ts",
    "start": "node dist/main.js",
    "test": "jest"
  },
  "version": "0.1.0"
}
