    "stripe": "^20.4.1",
    "twilio": "^5.13.0",
    "typeorm": "^0.3.23"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.16",
    "@swc/core": "^1.11.29",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.16.0",
    "@types/nodemailer": "^7.0.11",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  },
  "name": "@cannasaas/api",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "db:migrate": "typeorm migration:run -d src/config/database.config.ts",
    "db:migrate:generate": "typeorm migration:generate -d src/config/database.config.ts",
    "db:seed": "ts-node -r tsconfig-paths/register src/database/seeds/run-seeds.ts",
    "dev": "ts-node --swc -r tsconfig-paths/register src/main.ts",
    "lint": "eslint src --ext .ts",
    "migration:generate": "ts-node --swc -r tsconfig-paths/register ./node_modules/typeorm/cli migration:generate src/migrations/InitialSchema -d src/data-source.ts",
    "migration:revert": "ts-node --swc -r tsconfig-paths/register ./node_modules/typeorm/cli migration:revert -d src/data-source.ts",
    "migration:run": "ts-node --swc -r tsconfig-paths/register ./node_modules/typeorm/cli migration:run -d src/data-source.ts",
    "start": "node dist/main.js",
    "test": "jest",
    "test:e2e": "jest --config jest-e2e.config.js --runInBand --forceExit"
  },
  "version": "0.1.0"
}
