{
  "name": "@cannasaas/ui",
  "version": "1.0.0",
  "description": "GreenStack shared UI components and design system",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./src/greenstack-design-system.css": "./src/greenstack-design-system.css",
    "./src/themes/*": "./src/themes/*"
