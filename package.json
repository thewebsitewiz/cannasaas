{
  "devDependencies": {
    "@commitlint/config-conventional": "^20.5.0",
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/client-preset": "^5.2.4",
    "@types/cookie-parser": "^1.4.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "commitlint": "^20.5.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.2.2",
    "turbo": "^2.8.20",
    "@typescript/native-preview": "^7.0.0-dev",
    "typescript": "^5.8.3",
    "vite": "^8.0.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{json,md,yaml,yml,css}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ]
  },
  "name": "cannasaas",
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "@swc/helpers": "^0.5.17",
      "@types/react-dom": "^19.2.3"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "@types/react",
        "@types/react-dom"
      ]
    }
  },
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:api": "turbo run build --filter=@cannasaas/api",
    "clean": "turbo run clean && rimraf node_modules",
    "codegen": "graphql-codegen --config codegen.yml",
    "db:migrate": "turbo run db:migrate --filter=@cannasaas/api",
    "db:migrate:gen": "pnpm --filter @cannasaas/api typeorm migration:generate",
    "db:migrate:revert": "pnpm --filter @cannasaas/api typeorm migration:revert",
    "db:seed": "turbo run db:seed --filter=@cannasaas/api",
    "dev": "turbo run dev --parallel",
    "dev:admin": "turbo run dev --filter=@cannasaas/admin",
    "dev:api": "turbo run dev --filter=@cannasaas/api",
    "dev:kiosk": "turbo run dev --filter=@cannasaas/kiosk",
    "dev:sites": "turbo run dev --filter=@cannasaas/storefront --filter=@cannasaas/admin --filter=@cannasaas/staff --filter=@cannasaas/kiosk --parallel",
    "dev:staff": "turbo run dev --filter=@cannasaas/staff",
    "dev:storefront": "turbo run dev --filter=@cannasaas/storefront",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yaml}\"",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "prepare": "husky",
    "test": "turbo run test",
    "test:coverage": "turbo run test -- --coverage",
    "test:e2e": "turbo run test:e2e",
    "test:watch": "turbo run test -- --watch",
    "type-check": "turbo run type-check",
    "type-check:native": "tsgo --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.95.2",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "zustand": "^5.0.12"
  }
}
