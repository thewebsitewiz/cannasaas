# ═══════════════════════════════════════════════════════════════════════════
# CannaSaas — Environment Configuration
# Copy to .env and fill in production values
# ═══════════════════════════════════════════════════════════════════════════

# ── Core ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
CORS_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com,https://staff.yourdomain.com

# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://cannasaas:CHANGE_ME@postgres:5432/cannasaas
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=30

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379
REDIS_PREFIX=cannasaas:

# ── Auth / JWT ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_GENERATE_64_BYTE_HEX
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_64_BYTE_HEX_DIFFERENT
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ── Encryption ───────────────────────────────────────────────────────────
# Used for Metrc credential encryption (AES-256)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_GENERATE_32_BYTE_HEX

# ── Email (SendGrid SMTP or any SMTP provider) ──────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.your_sendgrid_api_key_here
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=CannaSaas

# ── SMS (Twilio) ─────────────────────────────────────────────────────────
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=+1XXXXXXXXXX

# ── Metrc Integration ───────────────────────────────────────────────────
METRC_INTEGRATOR_API_KEY=
METRC_SANDBOX_MODE=false
METRC_BASE_URL_NY=https://api-ny.metrc.com
METRC_BASE_URL_NJ=https://api-nj.metrc.com
METRC_BASE_URL_CT=https://api-ct.metrc.com

# ── AWS (S3 for images, optional) ────────────────────────────────────────
AWS_REGION=us-east-1
AWS_S3_BUCKET=cannasaas-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Stripe (Payment processing) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ── Frontend URLs (for CORS + email links) ───────────────────────────────
STOREFRONT_URL=https://yourdomain.com
ADMIN_URL=https://admin.yourdomain.com
STAFF_URL=https://staff.yourdomain.com

# ── OpenSearch (optional — for advanced product search) ──────────────────
# OPENSEARCH_ENDPOINT=http://opensearch:9200
# OPENSEARCH_USERNAME=admin
# OPENSEARCH_PASSWORD=admin
# OPENSEARCH_INDEX_PREFIX=cannasaas_prod_
