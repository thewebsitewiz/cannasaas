        numeric counted_qty
        numeric expected_qty
    }
    inventory_adjustments {
        uuid adjustment_id PK
        uuid dispensary_id FK
        uuid variant_id FK
        int reason_id FK
        numeric delta
    }
    orders {
        uuid order_id PK
        uuid dispensary_id FK
