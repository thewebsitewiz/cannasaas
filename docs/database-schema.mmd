    %% ──────────────────────────────────────────────────────────
    %% Entity definitions (PKs + FKs + a few load-bearing columns
    %% per table; full column lists live in data-dictionary.md)
    %% ──────────────────────────────────────────────────────────

    organizations {
        uuid organization_id PK
        varchar name
    }
    companies {
        uuid company_id PK
        uuid organization_id FK
        varchar name
    }
    dispensaries {
        uuid entity_id PK
        uuid company_id FK
        varchar name
        varchar slug
        varchar state
        bool is_active
    }
    users {
        uuid id PK
        uuid organization_id FK
        uuid dispensary_id FK
        varchar email UK
        varchar role
        bool is_active
    }
    customer_profiles {
        uuid profile_id PK
        uuid user_id FK
        uuid preferred_dispensary_id FK
        date date_of_birth
        bool sms_opt_in
        bool marketing_opt_in
    }
    employee_profiles {
        uuid profile_id PK
        uuid user_id FK
        uuid dispensary_id FK
        int position_id FK
        date hire_date
    }
    customer_addresses {
        uuid address_id PK
        uuid user_id FK
        varchar line1
        varchar city
        varchar state
        varchar zip
    }
    age_verifications {
        uuid verification_id PK
        uuid user_id FK
        uuid dispensary_id FK
        timestamptz verified_at
    }
    refresh_tokens {
        uuid id PK
        uuid user_id FK
        uuid dispensary_id FK
        timestamptz expires_at
        bool is_revoked
    }
    kiosk_devices {
        uuid id PK
        uuid user_id FK,UK
        uuid dispensary_id FK
        varchar label
        text public_key
    }
    brands {
        uuid brand_id PK
        uuid organization_id FK
        varchar name
        varchar logo_url
    }
    manufacturers {
        uuid manufacturer_id PK
        uuid brand_id FK
        varchar name
    }
    strain_data {
        uuid strain_data_id PK
        varchar strain_name
        varchar type
    }
    products {
        uuid id PK
        uuid dispensary_id FK
        uuid brand_id FK
        uuid manufacturer_id FK
        uuid strain_id FK
        int product_type_id FK
        int primary_category_id FK
        int tax_category_id FK
        int packaging_type_id FK
        int extraction_method_id FK
        int uom_id FK
        int metrc_item_category_id FK
        varchar name
        bool is_active
        int sort_order
    }
    product_variants {
        uuid variant_id PK
        uuid product_id FK
        uuid dispensary_id FK
        int uom_id FK
        numeric size
    }
    product_batches {
        uuid batch_id PK
        uuid variant_id FK
        uuid dispensary_id FK
        uuid manufacturer_id FK
